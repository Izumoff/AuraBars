#include "resource.h"
#include <windows.h>

LANGUAGE LANG_ENGLISH, SUBLANG_DEFAULT

IDD_OPTIONS DIALOGEX 0, 0, 240, 232
STYLE DS_CONTROL | WS_CHILD | WS_VISIBLE | WS_TABSTOP
EXSTYLE WS_EX_CONTROLPARENT
FONT 8, "MS Shell Dlg"
BEGIN
    // Manual tab strip built from plain radio-style pushbuttons (not a
    // SysTabControl32) - the standard BUTTON class is guaranteed available
    // in every host, sidestepping any comctl32 tab-class registration
    // issues in AIMP's own options-dialog host process. Six tabs need two
    // rows to fit the dialog's fixed width.
    CONTROL         "System", IDC_TAB_BTN0, "Button", BS_AUTORADIOBUTTON | BS_PUSHLIKE | WS_GROUP | WS_TABSTOP, 4, 4, 75, 16
    CONTROL         "Scaling", IDC_TAB_BTN1, "Button", BS_AUTORADIOBUTTON | BS_PUSHLIKE | WS_TABSTOP, 81, 4, 75, 16
    CONTROL         "Bars", IDC_TAB_BTN2, "Button", BS_AUTORADIOBUTTON | BS_PUSHLIKE | WS_TABSTOP, 158, 4, 75, 16
    CONTROL         "Peaks", IDC_TAB_BTN3, "Button", BS_AUTORADIOBUTTON | BS_PUSHLIKE | WS_TABSTOP, 4, 22, 75, 16
    CONTROL         "Background", IDC_TAB_BTN4, "Button", BS_AUTORADIOBUTTON | BS_PUSHLIKE | WS_TABSTOP, 81, 22, 75, 16
    CONTROL         "Layout", IDC_TAB_BTN5, "Button", BS_AUTORADIOBUTTON | BS_PUSHLIKE | WS_TABSTOP, 158, 22, 75, 16

    // --- Tab 0: System ---
    LTEXT           "Version:", IDC_LBL_VERSION, 10, 46, 130, 10
    LTEXT           "", IDC_LBL_VERSION_VALUE, 150, 46, 82, 10
    PUSHBUTTON      "Reset to Defaults", IDC_RESET_DEFAULTS_BTN, 10, 62, 150, 14
    CONTROL         "Debug logging (writes to %TEMP%\AuraBars_debug.log, 1/sec)", IDC_DEBUGLOG_CHECK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 82, 220, 20

    // --- Tab 1: Scaling ---
    LTEXT           "Amplitude scaling:", IDC_LBL_AMPSCALE, 10, 46, 130, 10
    COMBOBOX        IDC_AMPSCALE_COMBO, 150, 44, 82, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "dB floor (-100 to -20):", IDC_LBL_DBFLOOR, 10, 62, 130, 10
    EDITTEXT        IDC_DBFLOOR_EDIT, 150, 60, 82, 12, ES_AUTOHSCROLL

    LTEXT           "dB ceiling (-20 to 0):", IDC_LBL_DBCEILING, 10, 78, 130, 10
    EDITTEXT        IDC_DBCEILING_EDIT, 150, 76, 82, 12, ES_AUTOHSCROLL

    CONTROL         "Auto-gain ceiling (overrides dB ceiling above)", IDC_AUTOGAIN_CHECK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 94, 220, 10

    LTEXT           "Number of bars (8-128):", IDC_LBL_BARCOUNT, 10, 110, 130, 10
    EDITTEXT        IDC_BARCOUNT_EDIT, 150, 108, 82, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "Segment gap (LED, px, 1-8):", IDC_LBL_SEGMENTGAP, 10, 126, 130, 10
    EDITTEXT        IDC_SEGMENTGAP_EDIT, 150, 124, 82, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "Segment height (LED, px, 4-20):", IDC_LBL_SEGMENTHEIGHT, 10, 142, 130, 10
    EDITTEXT        IDC_SEGMENTHEIGHT_EDIT, 150, 140, 82, 12, ES_AUTOHSCROLL | ES_NUMBER

    // --- Tab 2: Bars ---
    LTEXT           "Bar style:", IDC_LBL_BARSTYLE, 10, 46, 130, 10
    COMBOBOX        IDC_BARSTYLE_COMBO, 150, 44, 82, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Bar color mode:", IDC_LBL_BARCOLORMODE, 10, 62, 130, 10
    COMBOBOX        IDC_BARCOLORMODE_COMBO, 150, 60, 82, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Bar color:", IDC_LBL_BARCOLOR, 10, 79, 130, 10
    PUSHBUTTON      "#D9702C", IDC_BARCOLOR_BTN, 150, 76, 82, 14

    LTEXT           "Gradient top color:", IDC_LBL_BARGRADTOP, 10, 95, 130, 10
    PUSHBUTTON      "#E0B23C", IDC_BARGRADTOP_BTN, 150, 92, 82, 14

    LTEXT           "Gradient bottom color:", IDC_LBL_BARGRADBOTTOM, 10, 111, 130, 10
    PUSHBUTTON      "#C62F2F", IDC_BARGRADBOTTOM_BTN, 150, 108, 82, 14

    LTEXT           "Bar spacing (px, 0-20):", IDC_LBL_BARSPACING, 10, 127, 130, 10
    EDITTEXT        IDC_BARSPACING_EDIT, 150, 124, 82, 12, ES_AUTOHSCROLL | ES_NUMBER

    // --- Tab 3: Peaks ---
    CONTROL         "Peak markers", IDC_PEAKMARKERS_CHECK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 46, 90, 10
    PUSHBUTTON      "#D8D8D8", IDC_PEAKCOLOR_BTN, 150, 44, 82, 14

    LTEXT           "Peak fall speed (px/frame, 0.1-10.0):", IDC_LBL_PEAKFALLSPEED, 10, 63, 140, 10
    EDITTEXT        IDC_PEAKFALLSPEED_EDIT, 150, 60, 82, 12, ES_AUTOHSCROLL

    LTEXT           "Peak marker thickness (Smooth, 1-10):", IDC_LBL_PEAKTHICKNESS, 10, 79, 140, 10
    EDITTEXT        IDC_PEAKTHICKNESS_EDIT, 150, 76, 82, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "Peak marker height, segments (LED, 1-3):", IDC_LBL_PEAKHEIGHTSEG, 10, 95, 140, 10
    EDITTEXT        IDC_PEAKHEIGHTSEG_EDIT, 150, 92, 82, 12, ES_AUTOHSCROLL | ES_NUMBER

    // --- Tab 4: Background ---
    LTEXT           "Background style:", IDC_LBL_BACKSTYLE, 10, 46, 130, 10
    COMBOBOX        IDC_BACKSTYLE_COMBO, 150, 44, 82, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Background color:", IDC_LBL_BACKCOLOR, 10, 63, 130, 10
    PUSHBUTTON      "#0A0A0A", IDC_BACKCOLOR_BTN, 150, 60, 82, 14

    CONTROL         "Grid lines", IDC_GRIDLINES_CHECK, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 79, 90, 10
    PUSHBUTTON      "#333333", IDC_GRIDCOLOR_BTN, 150, 76, 82, 14

    // --- Tab 5: Layout ---
    LTEXT           "Top margin (%, 0-30):", IDC_LBL_TOPMARGIN, 10, 46, 130, 10
    EDITTEXT        IDC_TOPMARGIN_EDIT, 150, 44, 82, 12, ES_AUTOHSCROLL | ES_NUMBER
END
